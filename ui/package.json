{
  "name": "xii-django-river-admin-ui",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "vite",
    "dev": "vite",
    "prebuild": "rm -rf ../xii/django_river_admin/templates/* && rm -rf ../xii/django_river_admin/static/*",
    "build": "vite build",
    "postbuild": "mkdir -p ../xii/django_river_admin/templates && mv ../xii/django_river_admin/static/index.html ../xii/django_river_admin/templates/index.html",
