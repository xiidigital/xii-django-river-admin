    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.28.0",
    "@mdi/font": "^7.4.47",
    "axios": "^1.7.2",
    "codemirror": "^6.0.1",
    "d3": "^7.9.0",
    "d3-tip": "^0.9.1",
    "dagre-d3": "^0.6.4",
    "mitt": "^3.0.1",
    "vue": "^3.4.31",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^4.4.0",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.6.11",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/eslint-config-prettier": "^9.0.0",
